{
  "name": "ai-interview-sdk",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Open-source TypeScript/React infrastructure for embedding AI-powered interviews into any application, with your own AI keys, backend, and database.",
  "license": "MIT",
  "homepage": "https://github.com/Yuvakunaal/ai-interview-sdk#readme",
  "bugs": {
    "url": "https://github.com/Yuvakunaal/ai-interview-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Yuvakunaal/ai-interview-sdk.git"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "turbo run build",
    "build:site": "pnpm --filter @interview-sdk/landing build && pnpm --filter @interview-sdk/docs build && node scripts/compose-site.mjs",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.9.5",
    "tsup": "^8.5.1",
    "turbo": "^2.10.5",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
