{
  "name": "@interview-sdk/core",
  "version": "0.1.1",
  "description": "Framework-independent flow, evaluation, rubric, and follow-up engine for AI-powered interviews.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Yuvakunaal/ai-interview-sdk.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Yuvakunaal/ai-interview-sdk/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/Yuvakunaal/ai-interview-sdk/issues"
  },
  "keywords": [
    "ai-interview",
    "interview-sdk"
  ],
  "dependencies": {
    "zod": "^4.4.3"
  }
}
