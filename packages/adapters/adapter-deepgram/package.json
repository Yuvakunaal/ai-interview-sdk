{
  "name": "@interview-sdk/adapter-deepgram",
  "version": "0.0.0",
  "description": "Deepgram voice (speech-to-text) provider adapter for @interview-sdk/core.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Yuvakunaal/ai-interview-sdk.git",
    "directory": "packages/adapters/adapter-deepgram"
  },
  "keywords": [
    "ai-interview",
    "interview-sdk",
    "adapter"
  ],
  "dependencies": {
    "@deepgram/sdk": "^5.5.0",
    "@interview-sdk/core": "workspace:*"
  }
}
