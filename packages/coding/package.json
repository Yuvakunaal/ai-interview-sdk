{
  "name": "@interview-sdk/coding",
  "version": "0.1.2",
  "description": "Sandboxed code execution and evaluation for Coding Interview Mode, isolated in its own package so a sandbox vulnerability can't compromise the rest of the SDK.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Yuvakunaal/ai-interview-sdk.git",
    "directory": "packages/coding"
  },
  "homepage": "https://github.com/Yuvakunaal/ai-interview-sdk/tree/main/packages/coding#readme",
  "bugs": {
    "url": "https://github.com/Yuvakunaal/ai-interview-sdk/issues"
  },
  "keywords": [
    "ai-interview",
    "interview-sdk",
    "sandbox",
    "coding-interview"
  ],
  "dependencies": {
    "@interview-sdk/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0"
  }
}
