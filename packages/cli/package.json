{
  "name": "@interview-sdk/cli",
  "version": "0.0.0",
  "description": "Scaffolding, Interview Simulator, and Bias & Consistency Testing Harness for AI-powered interviews.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "interview-sdk": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "tsup && chmod +x dist/cli.js",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/interview-sdk/interview-sdk.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "ai-interview",
    "interview-sdk",
    "cli"
  ],
  "dependencies": {
    "@interview-sdk/core": "workspace:*"
  }
}
