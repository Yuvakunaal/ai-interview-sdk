# Signs every evaluation returned by /api/interview/answer so
# /api/interview/complete can verify none of them were tampered with in the
# browser before the interview finished (see the "Verifying the final
# report" section of this example's README). Optional, but recommended.
INTERVIEW_SIGNING_SECRET=

# app/api/interview/answer/route.ts uses a mock adapter by default so this
# example runs with zero setup. Swap in a real @interview-sdk/adapter-*
# (see the TODO in that file) and add its API key here, e.g.:
# OPENAI_API_KEY=
